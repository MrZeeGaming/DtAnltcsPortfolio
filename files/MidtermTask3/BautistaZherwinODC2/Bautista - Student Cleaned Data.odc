13;&#10;    #&quot;Removed Columns1&quot; = Table.RemoveColumns(#&quot;Inserted Prefix&quot;,{&quot;Index&quot;}),&#13;&#10;    #&quot;Renamed Columns4&quot; = Table.RenameColumns(#&quot;Removed Columns1&quot;,{{&quot;Prefix&quot;, &quot;Course Id&quot;}}),&#13;&#10;    #&quot;Reordered Columns3&quot; = Table.ReorderColumns(#&quot;Renamed Columns4&quot;,{&quot;Course Id&quot;, &quot;CourseCode&quot;, &quot;CourseTitle&quot;, &quot;Instructor&quot;, &quot;InstructorEmail&quot;, &quot;Room&quot;})&#13;&#10;in&#13;&#10;    #&quot;Reordered Columns3&quot;]]&gt;&lt;/Formula&gt;&lt;IsParameterQuery xsi:nil=&quot;true&quot; /&gt;&lt;IsDirectQuery xsi:nil=&quot;true&quot; /&gt;&lt;/Query&gt;&lt;/Items&gt;&lt;/Mashup&gt;</odc:PowerQueryMashupData>
